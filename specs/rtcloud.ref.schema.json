{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/rtcloud.ref.schema.json",
  "title": "RTCloud Ref v1",
  "type": "object",
  "required": ["name", "snapshot_id"],
  "properties": {
    "name": {"type": "string", "minLength": 1},
    "snapshot_id": {"type": "string", "pattern": "^[a-z0-9]+:[a-f0-9]+$"}
  },
  "additionalProperties": false
}
